<table class="table">
    <thead>
    <tr>
        <th>ID</th>
        <th>상품명</th>
        <th>가격</th>
        <th>관리</th>
    </tr>
    </thead>
    <tbody>
    {{#products}}
        <tr>
            <td>{{id}}</td>
            <td><a href="/products/{{id}}">{{productName}}</a></td>
            <td>{{price}}</td>
            <td>
                <a href="/products/edit/{{id}}" class="btn btn-primary">Edit</a>

                <a href="/products/delete/{{id}}" class="btn btn-danger"
                   onclick="return confirm('정말 삭제하시겠습니까?')">Delete</a>
            </td>
        </tr>
    {{/products}}
    </tbody>
</table>